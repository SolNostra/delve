; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="DELVE"
run/main_scene="uid://ffyv0j2ruof3"
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="res://ui/assets/icon.svg"

[autoload]

PhantomCameraManager="*uid://duq6jhf6unyis"
PlayerManager="*uid://n875a11kc1gj"
DialogueManager="*uid://c3rodes2l3gxb"
State="*uid://bufuh1oefqdto"

[dialogue_manager]

runtime/balloon_path="res://ui/assets/dialogue/balloon.tscn"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=3
window/size/borderless=true

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogue_manager/plugin.cfg", "res://addons/phantom_camera/plugin.cfg")

[filesystem]

import/blender/enabled=false

[global_group]

player=""

[gui]

theme/custom="uid://bq53pwtkpigch"
theme/custom_font="uid://is4fcxcpf8wm"

